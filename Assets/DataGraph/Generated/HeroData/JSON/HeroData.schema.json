{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HeroData",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "properties": {
      "name": {"type": "string"},
      "groups": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "skills": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "skillName": {"type": "string"},
                  "skillDmg": {"type": "integer"}
                }
              }
            }
          }
        }
      }
    }
  }
}
