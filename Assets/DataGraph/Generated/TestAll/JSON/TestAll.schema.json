{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TestAll",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "properties": {
      "dmg": {"type": "integer"},
      "speed": {"type": "number"},
      "isRare": {"type": "boolean"},
      "spawnPont": {
        "type": "object",
        "properties": {
          "x": {"type": "number"},
          "y": {"type": "number"},
          "z": {"type": "number"}
        },
        "required": ["x", "y", "z"]
      },
      "pos": {
        "type": "object",
        "properties": {
          "x": {"type": "number"},
          "y": {"type": "number"}
        },
        "required": ["x", "y"]
      },
      "tint": {
        "type": "object",
        "properties": {
          "r": {"type": "number"},
          "g": {"type": "number"},
          "b": {"type": "number"},
          "a": {"type": "number"}
        },
        "required": ["r", "g", "b", "a"]
      },
      "damage": {
        "type": "object",
        "properties": {
          "score": {"type": "integer"},
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
