{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Equip",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "properties": {
      "name": {"type": "string"},
      "rewards": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "itemId": {"type": "integer"},
            "qty": {"type": "integer"}
          }
        }
      }
    }
  }
}
