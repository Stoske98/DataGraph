{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gear",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "properties": {
      "name": {"type": "string"},
      "skills": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "skillId": {"type": "integer"},
            "levels": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "req": {"type": "integer"},
                  "power": {"type": "integer"}
                }
              }
            }
          }
        }
      }
    }
  }
}
